<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Patel Hardware Web Application</display-name>

    <!-- ============================================
         Jersey JAX-RS Servlet
         ============================================ -->
    <servlet>
        <servlet-name>JerseyServlet</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>jersey.config.server.provider.packages</param-name>
            <param-value>com.patelhardware.servlet</param-value>
        </init-param>
        <init-param>
            <param-name>jersey.config.server.provider.classnames</param-name>
            <param-value>org.glassfish.jersey.jackson.JacksonFeature</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>JerseyServlet</servlet-name>
        <url-pattern>/api/*</url-pattern>
    </servlet-mapping>

    <!-- ============================================
         Login Servlet
         ============================================ -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.patelhardware.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- ============================================
         Registration Servlet
         ============================================ -->
    <servlet>
        <servlet-name>RegistrationServlet</servlet-name>
        <servlet-class>com.patelhardware.servlet.RegistrationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegistrationServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- ============================================
         Main / Home Servlet
         ============================================ -->
    <servlet>
        <servlet-name>MainServlet</servlet-name>
        <servlet-class>com.patelhardware.servlet.MainServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MainServlet</servlet-name>
        <url-pattern>/main</url-pattern>
    </servlet-mapping>

    <!-- ============================================
         View All Items Servlet
         ============================================ -->
    <servlet>
        <servlet-name>ViewAllServlet</servlet-name>
        <servlet-class>com.patelhardware.servlet.ViewAllServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewAllServlet</servlet-name>
        <url-pattern>/viewall</url-pattern>
    </servlet-mapping>

    <!-- ============================================
         Buy Items Servlet
         ============================================ -->
    <servlet>
        <servlet-name>BuyItemsServlet</servlet-name>
        <servlet-class>com.patelhardware.servlet.BuyItemsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BuyItemsServlet</servlet-name>
        <url-pattern>/buy</url-pattern>
    </servlet-mapping>

    <!-- ============================================
         View Cart Items Servlet
         ============================================ -->
    <servlet>
        <servlet-name>ViewCartItemsServlet</servlet-name>
        <servlet-class>com.patelhardware.servlet.ViewCartItemsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewCartItemsServlet</servlet-name>
        <url-pattern>/cart</url-pattern>
    </servlet-mapping>

    <!-- ============================================
         Search Items Servlet
         ============================================ -->
    <servlet>
        <servlet-name>SearchItemsServlet</servlet-name>
        <servlet-class>com.patelhardware.servlet.SearchItemsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchItemsServlet</servlet-name>
        <url-pattern>/search</url-pattern>
    </servlet-mapping>

    <!-- Default welcome page -->
    <welcome-file-list>
        <welcome-file>html/login.html</welcome-file>
    </welcome-file-list>

    <!-- Session timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
